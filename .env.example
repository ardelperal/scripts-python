
# Archivo de ejemplo para configuración de entorno
# Copia este archivo como .env y personaliza los valores

# Configuración del entorno
ENVIRONMENT=local
#ENVIRONMENT=oficina

# Configuración de base de datos
DB_PASSWORD=tu_password_aqui

# Rutas de bases de datos - Entorno LOCAL
LOCAL_DB_BRASS=dbs-locales/Gestion_Brass_Gestion_Datos.accdb
LOCAL_DB_TAREAS=dbs-locales/Tareas_datos1.accdb
LOCAL_DB_CORREOS=dbs-locales/correos_datos.accdb
LOCAL_DB_NOCONFORMIDADES=dbs-locales/NoConformidades_Datos.accdb
LOCAL_DB_LANZADERA=dbs-locales/Lanzadera_Datos.accdb
LOCAL_CSS_FILE=herramientas/CSS.txt

# Rutas de bases de datos - Entorno OFICINA
OFFICE_DB_BRASS=\\datoste\Aplicaciones_dys\Aplicaciones PpD\BRASS\Gestion_Brass_Gestion_Datos.accdb
OFFICE_DB_TAREAS=\\datoste\Aplicaciones_dys\Aplicaciones PpD\00Recursos\Tareas_datos1.accdb
OFFICE_DB_CORREOS=\\datoste\aplicaciones_dys\Aplicaciones PpD\00Recursos\correos_datos.accdb
OFFICE_DB_NOCONFORMIDADES=\\datoste\Aplicaciones_dys\Aplicaciones PpD\No Conformidades\NoConformidades_Datos.accdb
OFFICE_DB_LANZADERA=\\datoste\Aplicaciones_dys\Aplicaciones PpD\0Lanzadera\Lanzadera_Datos.accdb
OFFICE_CSS_FILE=\\datoste\Aplicaciones_dys\Aplicaciones PpD\CSS.txt

# Configuración de correo
DEFAULT_RECIPIENT=tu.email@empresa.com

# SMTP LOCAL
LOCAL_SMTP_SERVER=localhost
LOCAL_SMTP_PORT=1025
LOCAL_SMTP_USER=test@example.com
LOCAL_SMTP_PASSWORD=
LOCAL_SMTP_TLS=false

# SMTP OFICINA
OFFICE_SMTP_SERVER=10.73.54.85
OFFICE_SMTP_PORT=25
OFFICE_SMTP_USER=
OFFICE_SMTP_PASSWORD=
OFFICE_SMTP_TLS=false

# SMTP ALTERNATIVO (para cuando no se puede acceder al servidor de oficina)
# Descomenta y configura estas variables si necesitas usar un servidor SMTP alternativo
# SMTP_OVERRIDE_SERVER=localhost
# SMTP_OVERRIDE_PORT=1025
# SMTP_OVERRIDE_USER=
# SMTP_OVERRIDE_PASSWORD=
# SMTP_OVERRIDE_TLS=false

# IDs de Aplicaciones
APP_ID_AGEDYS=3
APP_ID_BRASS=6
APP_ID_NOCONFORMIDADES=8
APP_ID_EXPEDIENTES=19

# Configuración de logging
LOG_LEVEL=INFO
LOG_FILE=logs/brass.log
